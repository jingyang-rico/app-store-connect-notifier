# ── App Store Connect API auth ──────────────────────────────────────────
# Key ID and Issuer ID from App Store Connect → Users and Access →
# Integrations → App Store Connect API. The private key (.p8) itself is NOT
# set here — drop the file at ./secrets/AuthKey.p8 and docker-compose loads it.
SPACESHIP_CONNECT_API_KEY_ID=
SPACESHIP_CONNECT_API_ISSUER_ID=

# ── Apps to monitor ─────────────────────────────────────────────────────
# Comma-separated bundle identifiers, e.g. com.acme.localall,com.acme.bible
BUNDLE_IDENTIFIERS=

# ── Slack ───────────────────────────────────────────────────────────────
# Incoming Webhook URL for the target channel.
BOT_SLACK_WEBHOOK_URL=
# Optional override of the channel name (default: #ios-app-updates).
# SLACK_CHANNEL_NAME=#ios-app-updates

# ── Polling ─────────────────────────────────────────────────────────────
POLL_TIME_IN_SECONDS=300
NUMBER_OF_BUILDS=1

# Optional: only needed if your account belongs to multiple teams.
# ITC_TEAM_IDS=
